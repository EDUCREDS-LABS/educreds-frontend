# Frontend Environment Variables
# Copy this file to .env.development, .env.production, etc. and fill in your actual values

# Development Environment
NODE_ENV=

# API Endpoints
VITE_API_BASE=
VITE_CERT_API_BASE=
VITE_MARKETPLACE_API_BASE=

# Security & Development
DISABLE_CSP=

# Contract Configuration
VITE_CREDENTIAL_ISSUER_ADDRESS=
VITE_CONTRACT_ADDRESS=
VITE_ETHEREUM_RPC_URL=
VITE_ENABLE_WALLET_DIRECT_ISSUANCE=true

# Development-specific Settings
VITE_DEV_MODE=
VITE_DEBUG=

# Reown AppKit Configuration (for wallet connection)
# Get your Project ID from https://dashboard.reown.com/
NEXT_PUBLIC_PROJECT_ID=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# PayPal Configuration
# Get your Client ID from https://developer.paypal.com/developer/applications
VITE_PAYPAL_CLIENT_ID=

# Crypto Payment Configuration (uses Reown AppKit for wallet connection)
# Already configured above with NEXT_PUBLIC_PROJECT_ID
