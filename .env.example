# Frontend Environment Variables
# Copy this file to .env.development, .env.production, etc. and fill in your actual values

# Development Environment
NODE_ENV=

# API Endpoints
VITE_API_BASE=
VITE_CERT_API_BASE=
VITE_MARKETPLACE_API_BASE=

# Security & Development
DISABLE_CSP=

# Contract Configuration
VITE_CONTRACT_ADDRESS=
VITE_ETHEREUM_RPC_URL=

# Development-specific Settings
VITE_DEV_MODE=
VITE_DEBUG=

# Reown AppKit Configuration (for wallet connection)
# Get your Project ID from https://dashboard.reown.com/
NEXT_PUBLIC_PROJECT_ID=
